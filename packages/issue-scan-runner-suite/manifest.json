{
  "kind": "issue_scan_runner_suite_package_manifest",
  "suite_id": "issue-scan-runner-suite",
  "lifecycle_version": "civilization_issue_to_human_ready_pr_v0.9",
  "terminal_stage_path": "managed_ready_pr_finalizer",
  "validation_command": "hive factory validate-issue-scan-runner-suite --package packages/issue-scan-runner-suite",
  "components": [
    {
      "id": "stage_role_output_runner",
      "command": "runners/stage_role_output_runner.placeholder",
      "argv": [
        "--stdin-json"
      ],
      "timeout": "10m",
      "stdin_kind": "issue_scan_stage_role_output_runner_context",
      "stdout_kind": "hive.IssueScanStageRoleOutputRunnerResult",
      "required_env": [],
      "forbidden_env": [
        "ANTHROPIC_API_KEY",
        "HIVE_ANTHROPIC_API_KEY",
        "GITHUB_TOKEN"
      ],
      "authority_boundaries": [
        "planning evidence only",
        "does not implement code",
        "does not run adversarial review",
        "does not create, mark ready, approve, merge, or deploy a PR"
      ],
      "fixtures": {
        "stdin": "examples/stage_role_output_runner/stdin.json",
        "stdout": "examples/stage_role_output_runner/stdout.json"
      }
    },
    {
      "id": "implementation_runner",
      "command": "runners/implementation_runner.placeholder",
      "argv": [
        "--stdin-json"
      ],
      "timeout": "30m",
      "stdin_kind": "issue_scan_implementation_runner_context",
      "stdout_kind": "hive.IssueScanImplementationRunnerResult",
      "required_env": [],
      "forbidden_env": [
        "ANTHROPIC_API_KEY",
        "HIVE_ANTHROPIC_API_KEY",
        "GITHUB_TOKEN"
      ],
      "authority_boundaries": [
        "may modify the target worktree/branch only within the supplied repo context",
        "does not create, mark ready, approve, merge, or deploy a PR"
      ],
      "fixtures": {
        "stdin": "examples/implementation_runner/stdin.json",
        "stdout": "examples/implementation_runner/stdout.json"
      }
    },
    {
      "id": "adversarial_review_runner",
      "command": "runners/adversarial_review_runner.placeholder",
      "argv": [
        "--stdin-json"
      ],
      "timeout": "20m",
      "stdin_kind": "issue_scan_adversarial_review_context",
      "stdout_kind": "hive.IssueScanAdversarialReviewReceipt",
      "required_env": [],
      "forbidden_env": [
        "ANTHROPIC_API_KEY",
        "HIVE_ANTHROPIC_API_KEY",
        "GITHUB_TOKEN"
      ],
      "authority_boundaries": [
        "exact-head review evidence only",
        "does not repair blockers",
        "does not mark PRs ready",
        "does not approve, merge, or deploy"
      ],
      "fixtures": {
        "stdin": "examples/adversarial_review_runner/stdin.json",
        "stdout": "examples/adversarial_review_runner/stdout.json"
      }
    },
    {
      "id": "blocker_repair_runner",
      "command": "runners/blocker_repair_runner.placeholder",
      "argv": [
        "--stdin-json"
      ],
      "timeout": "30m",
      "stdin_kind": "issue_scan_blocker_repair_runner_context",
      "stdout_kind": "hive.IssueScanBlockerRepairRunnerResult",
      "required_env": [],
      "forbidden_env": [
        "ANTHROPIC_API_KEY",
        "HIVE_ANTHROPIC_API_KEY",
        "GITHUB_TOKEN"
      ],
      "authority_boundaries": [
        "may repair only after review blockers reopen implementation work",
        "may modify the target worktree/branch only within the supplied repo context",
        "does not create, mark ready, approve, merge, or deploy a PR"
      ],
      "fixtures": {
        "stdin": "examples/blocker_repair_runner/stdin.json",
        "stdout": "examples/blocker_repair_runner/stdout.json"
      }
    },
    {
      "id": "ready_state_review_runner",
      "command": "runners/ready_state_review_runner.placeholder",
      "argv": [
        "--stdin-json"
      ],
      "timeout": "20m",
      "stdin_kind": "issue_scan_ready_state_review_context",
      "stdout_kind": "hive.IssueScanReadyStateReviewReceipt",
      "required_env": [],
      "forbidden_env": [
        "ANTHROPIC_API_KEY",
        "HIVE_ANTHROPIC_API_KEY",
        "GITHUB_TOKEN"
      ],
      "authority_boundaries": [
        "used only with --issue-scan-ready-pr-mark-ready",
        "reviews the exact PR head after the managed finalizer performs the draft-to-ready transition",
        "does not approve, merge, deploy, or perform production migrations"
      ],
      "fixtures": {
        "stdin": "examples/ready_state_review_runner/stdin.json",
        "stdout": "examples/ready_state_review_runner/stdout.json"
      }
    }
  ]
}
