# loop/config.env — Loop deployment configuration.
#
# All environment-specific values for the hive loop live here.
# Scripts source this file. Prompts reference these paths.
# Override per-deployment; do not hardcode values in prompts or scripts.

# ─── Git ────────────────────────────────────────────────────────────
# Remote name to push to (must exist in git remote -v).
GIT_REMOTE="transpara-ai"

# GitHub org for PRs (used in: gh pr create --repo ${GIT_ORG}/${REPO_NAME}).
GIT_ORG="transpara-ai"

# Repo name on GitHub (not the local directory name).
REPO_NAME="hive"

# Protected branches — close.sh refuses to commit on these.
PROTECTED_BRANCHES="main master"

# ─── Repos ──────────────────────────────────────────────────────────
# Base directory containing all checked-out repos.
REPOS_BASE="$HOME/transpara-ai/repos"

# Repo directory names (local filesystem).
REPO_HIVE="lovyou-ai-hive"
REPO_EVENTGRAPH="lovyou-ai-eventgraph"
REPO_AGENT="lovyou-ai-agent"
REPO_WORK="lovyou-ai-work"
REPO_SITE="lovyou-ai-site"

# ─── Features ───────────────────────────────────────────────────────
# Set to "true" to enable posting iteration summaries to an API.
POST_ENABLED="false"

# API base URL and key for posting (only used if POST_ENABLED=true).
# WARNING: If you populate POST_API_KEY, do NOT commit this file.
# Use loop/config.local.env (gitignored) for secrets, or export them
# in your shell environment instead.
POST_API_BASE=""
POST_API_KEY=""

# Set to "true" to enable deployment (fly deploy, ship.sh, etc.).
DEPLOY_ENABLED="false"

# Deploy command (only used if DEPLOY_ENABLED=true).
DEPLOY_CMD=""

# ─── Checkpoint Recovery ───────────────────────────────────────────
# Open Brain MCP endpoint for checkpoint thought capture and recovery.
# When unset, checkpointing is disabled — agents cold-start on reboot.
# WARNING: OPEN_BRAIN_KEY is a secret. Use loop/config.local.env or
# export it in your shell environment instead of putting it here.
OPEN_BRAIN_URL=""
OPEN_BRAIN_KEY=""

# Maximum age of an Open Brain thought before it's treated as stale.
# Hives that restart frequently should use shorter values (e.g. 30m).
CHECKPOINT_STALENESS="2h"

# Iterations between heartbeat events on the chain when no boundary
# trigger has fired.
CHECKPOINT_HEARTBEAT_INTERVAL="10"

# ─── Research Absorption into Librarian (council 2026-04-16) ────────
# Binding condition: caps and allowlists declared before absorption lands.
# These govern the Librarian's outward-facing research queries.
LIBRARIAN_QUERY_CAP_PER_TASK="5"
LIBRARIAN_COST_CEILING_PER_QUERY="0.10"
LIBRARIAN_DOMAIN_ALLOWLIST=""  # comma-separated domains; empty = all allowed
